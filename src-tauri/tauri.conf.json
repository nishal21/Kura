{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kura",
  "version": "0.1.0",
  "identifier": "com.nishal21.kura",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Kura",
        "width": 1366,
        "height": 900,
        "resizable": true
      }
    ]
  }
}
